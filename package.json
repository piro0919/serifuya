{
  "babel": {
    "plugins": [
      [
        "react-css-modules",
        {
          "filetypes": {
            ".scss": {
              "syntax": "postcss-scss"
            }
          }
        }
      ]
    ],
    "presets": [
      "next/babel"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@react-hook/window-size": "3.0.7",
    "@zeit/next-css": "1.0.1",
    "@zeit/next-sass": "1.0.1",
    "axios": "1.15.2",
    "babel-plugin-react-css-modules": "5.2.6",
    "dayjs": "1.10.4",
    "file-saver": "2.0.5",
    "generic-names": "4.0.0",
    "next": "16.2.4",
    "next-compose-plugins": "2.2.1",
    "next-localization": "0.11.0",
    "next-manifest": "3.0.1",
    "next-seo": "7.2.0",
    "postcss-scss": "4.0.9",
    "rc-pagination": "5.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-h5-audio-player": "3.6.0",
    "react-hook-form": "7.73.1",
    "react-icons": "5.6.0",
    "react-no-ssr": "1.1.0",
    "react-share": "5.3.0",
    "react-switch": "7.1.0",
    "react-toastify": "11.1.0",
    "ress": "5.0.2",
    "sass": "1.43.3",
    "sass-mq": "7.0.0",
    "uniqid": "5.2.0",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@types/file-saver": "2.0.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-css-modules": "4.6.8",
    "@types/react-no-ssr": "1.1.1",
    "@types/uniqid": "5.2.0",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "babel-eslint": "10.1.0",
    "eslint": "10.2.1",
    "eslint-config-react-app": "7.0.1",
    "eslint-plugin-flowtype": "8.0.3",
    "eslint-plugin-import": "2.22.1",
    "eslint-plugin-jsx-a11y": "6.4.1",
    "eslint-plugin-react": "7.22.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "typescript": "6.0.3"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "jsx-a11y/anchor-is-valid": [
        "error",
        {
          "aspects": [
            "invalidHref",
            "preferButton"
          ],
          "components": [
            "Link"
          ],
          "specialLink": [
            "hrefLeft",
            "hrefRight"
          ]
        }
      ]
    }
  },
  "name": "nextjs",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint --fix --ext .ts,.tsx src/",
    "start": "next start"
  },
  "version": "0.1.0"
}
